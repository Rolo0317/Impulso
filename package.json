{
  "name": "impulso-vivienda",
  "version": "0.1.0",
  "private": true,
  "description": "Plataforma inmobiliaria inteligente con web publica, CRM, IA y automatizacion.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@impulso/web",
    "dev:web": "npm run dev --workspace=@impulso/web",
    "dev:api": "npm run start:dev --workspace=@impulso/api",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "typecheck": "npm run typecheck --workspaces"
  },
  "engines": {
    "node": ">=20"
  }
}
